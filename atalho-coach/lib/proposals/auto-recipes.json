       }
      },
      "ref": "linha_registro"
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.file.append",
      "params": {
       "WFFilePath": "registro_humor.txt",
       "WFInput": {
        "ref": "linha_registro"
       },
       "WFAppendFileWriteMode": "Append"
      }
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.notification",
      "params": {
       "WFNotificationActionTitle": "Humor Registrado!",
       "WFNotificationActionBody": "Seu registro diário foi adicionado ao arquivo com sucesso."
      }
     }
    ]
   },
   "en": {
    "name": "Quick Mood Tracker",
    "steps": [
     {
      "type": "action",
      "identifier": "is.workflow.actions.comment",
      "params": {
       "WFCommentActionText": "Logs your current mood and a brief explanation using voice dictation, saving it to a log file in iCloud Drive to track your well-being over time."
      }
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.list",
      "params": {
       "WFItems": [
