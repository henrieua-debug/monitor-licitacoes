     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.getbatterylevel",
      "params": {},
      "ref": "bateria"
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.date",
      "params": {
       "WFDateActionMode": "Current Date"
      },
      "ref": "fecha_actual"
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.format.date",
      "params": {
       "WFDate": {
        "ref": "fecha_actual"
       },
       "WFDateFormatStyle": "Medium",
       "WFTimeFormatStyle": "Short"
      },
      "ref": "fecha_formateada"
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.gettext",
      "params": {
       "WFTextActionText": {
        "text": [
         "Laptop cerrada el: ",
         {
          "ref": "fecha_formateada"
         },
         " | Batería: ",
         {
          "ref": "bateria"
         },
         "%"
        ]
       }
      },
      "ref": "texto_log"
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.file.append",
      "params": {
       "WFFilePath": "log_laptop.txt",
       "WFInput": {
        "ref": "texto_log"
       },
       "WFAppendFileWriteMode": "Append"
      }
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.notification",
      "params": {
       "WFNotificationActionTitle": "¡Listo para cerrar!",
       "WFNotificationActionBody": "El registro se guardó correctamente en iCloud Drive. Ya puedes cerrar la laptop."
      }
     }
    ]
   }
  }
 },
 {
