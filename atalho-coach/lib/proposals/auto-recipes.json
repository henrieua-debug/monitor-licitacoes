 {
  "id": "auto-20260709",
  "emoji": "🎁",
  "level": "medium",
  "title": {
   "pt": "Rastreador de Gastos Rápido",
   "en": "Quick Expense Tracker",
   "es": "Rastreador de Gastos Rápido"
  },
  "description": {
   "pt": "Este atalho ajuda a controlar suas finanças pessoais de forma instantânea.",
   "en": "This shortcut helps you track your personal finances instantly.",
   "es": "Este atajo te ayuda a controlar tus finanzas personales de forma instantánea."
  },
  "ir": {
   "pt": {
    "name": "Rastreador de Gastos Rápido",
    "steps": [
     {
      "type": "action",
      "identifier": "is.workflow.actions.comment",
      "params": {
       "WFCommentActionText": "Registra rapidamente um gasto com valor e categoria em um arquivo de texto no iCloud Drive para fácil controle financeiro posterior."
      }
     },
     {
      "type": "action",
      "identifier": "is.workflow.actions.ask",
      "params": {
       "WFAskActionPrompt": "Qual o valor do gasto?",
       "WFInputType": "Number"
      },
      "ref": "valor_gasto"
     },
     {
      "type": "action",
