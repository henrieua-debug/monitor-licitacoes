# ── IA do construtor: configure UMA das duas chaves ─────────────────────────
# Opção gratuita (recomendada para começar): Google Gemini — 1.500 gerações/dia
# sem cartão. Pegue a chave em https://aistudio.google.com → Get API key.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.5-flash

# Opção premium: Anthropic (melhor qualidade de geração). Se as duas chaves
# existirem, a Anthropic tem prioridade.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Fórum de sugestões (opcional) — Supabase free tier ───────────────────────
# Crie um projeto em https://supabase.com, rode supabase/setup.sql no SQL Editor
# e copie: Settings → API → Project URL e a service_role key.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# URL do servidor de assinatura (um Mac rodando signer/server.mjs).
# Opcional: sem ele, o app entrega o arquivo .shortcut NÃO assinado + instruções,
# e links de instalação em 1 toque ficam indisponíveis (iOS 15+ exige arquivo assinado).
SIGNER_URL=

# Token compartilhado com o servidor de assinatura (defina o mesmo valor lá).
SIGNER_TOKEN=
