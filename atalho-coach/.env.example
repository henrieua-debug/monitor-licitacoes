# Chave da API da Anthropic — obrigatória para o construtor com IA (/construtor).
# As propostas curadas e o onboarding funcionam sem ela.
ANTHROPIC_API_KEY=

# Modelo usado na geração. claude-opus-4-8 é o padrão recomendado;
# troque por claude-sonnet-5 ou claude-haiku-4-5 se o custo por geração importar mais que a qualidade.
ANTHROPIC_MODEL=claude-opus-4-8

# URL do servidor de assinatura (um Mac rodando signer/server.mjs).
# Opcional: sem ele, o app entrega o arquivo .shortcut NÃO assinado + instruções,
# e links de instalação em 1 toque ficam indisponíveis (iOS 15+ exige arquivo assinado).
SIGNER_URL=

# Token compartilhado com o servidor de assinatura (defina o mesmo valor lá).
SIGNER_TOKEN=
